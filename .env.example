# Google Cloud Vertex AI
# Authentication via ADC (run: gcloud auth application-default login)
GCP_PROJECT=memoire-agent-minecraft

# gemini-3.1-flash-lite is only available in location "global" -- if you want it,
# set GCP_LOCATION=global AND the two models below to gemini-3.1-flash-lite.
GCP_LOCATION=global

# IA model for code generation
GCP_MODEL=gemini-3.1-flash-lite

# IA model for curriculum task proposals (no code generation needed, so lighter model is fine)
GCP_MODEL_CURRICULUM=gemini-3.1-flash-lite

# Embedding model for semantic skill retrieval (RETRIEVAL_QUERY / RETRIEVAL_DOCUMENT)
GCP_EMBED_MODEL=gemini-embedding-001

# Model parameters
GCP_MAX_OUTPUT_TOKENS=8192
GCP_TEMPERATURE=0.7

# Minecraft Server Configuration
MC_HOST=localhost
MC_PORT=25565
# Base username. The bot actually joins as "<MC_USERNAME>_<iteration>"
# (e.g. Voyager-G_3) so each training run is a fresh Minecraft player.
MC_USERNAME=Voyager-G
MC_VERSION=1.20
# Difficulte appliquee par RCON au demarrage. "peaceful" = pas de mobs hostiles
# (evite les kicks de knockback). "easy"/"normal"/"hard" pour les advancements de combat.
MC_DIFFICULTY=peaceful

# Run identity
# Directory where the iteration counter is stored.
STATE_DIR=state
# Force a specific iteration number (and thus username). Leave empty to
# auto-manage: --clear bumps the iteration, a normal restart resumes the latest.
# RUN_ITERATION=

# RCON auto-OP
# Because the bot joins under a new name each iteration, it is auto-opped via
# RCON at spawn so it can run /scoreboard, /gamemode, /tp, etc.
# Requires server.properties: enable-rcon=true, rcon.password=<this value>, rcon.port=<this port>.
RCON_PORT=25575
RCON_PASSWORD=voyager-rcon
# Set to false to disable RCON auto-op entirely (then /op the bot manually).
RCON_ENABLED=true
# Set to false to op only, without applying the server setup (difficulty, gamerules,
# fall damage off, fire resistance + night vision, scoreboard).
RCON_APPLY_SETUP=true
# Intervalle (ms) de mise a jour du scoreboard sante/faim via RCON (alimente par l'app, pas le bot).
RCON_SCOREBOARD_MS=3000

# Observer (scan radius in blocks)
BLOCK_SCAN_RADIUS=32
ENTITY_SCAN_RADIUS=32

# Action Agent
ACTION_MAX_RETRIES=3
ACTION_RETRY_DELAY_MS=2000
ACTION_TIMEOUT_MS=90000

# Critic
# Delai (ms) apres l'action avant que le critic juge, pour laisser les objets
# tombes (minage) etre ramasses et eviter les faux rejets.
CRITIC_SETTLE_MS=1000

# Skill Library
SKILLS_LIBRARY_DIR=src/skills/learned
# How many of the most relevant learned skills to surface in the prompt
# (keeps token cost bounded as the library grows).
SKILL_RETRIEVAL_TOPK=12
# Max history items (learned skills / failed tasks) embedded in the curriculum prompt.
CURRICULUM_HISTORY_LIMIT=20

# Web Inventory Viewer (mineflayer-web-inventory)
# Open http://localhost:<INVENTORY_VIEWER_PORT> in your browser to see the bot inventory live
INVENTORY_VIEWER_PORT=3000

# Real-time Dashboard (Voyager tech tree graph)
# Open http://localhost:<DASHBOARD_PORT> in your browser to see the progress chart
DASHBOARD_PORT=3001

# Logging (debug | info | warn | error)
LOG_LEVEL=info
