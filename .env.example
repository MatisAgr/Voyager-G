# Google Cloud Vertex AI
# Authentication via ADC (run: gcloud auth application-default login)
GCP_PROJECT=memoire-agent-minecraft

# for France use europe-west9
# to use gemini-3.1-flash-lite-preview, the location must be global
GCP_LOCATION=global

# IA model for code generation
GCP_MODEL=gemini-3.1-flash-lite-preview

# IA model for curriculum task proposals (no code generation needed, so lighter model is fine)
GCP_MODEL_CURRICULUM=gemini-3.1-flash-lite-preview

# Model parameters
GCP_MAX_OUTPUT_TOKENS=8192
GCP_TEMPERATURE=0.7

# Minecraft Server Configuration
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=Voyager-G
MC_VERSION=1.20

# Observer (scan radius in blocks)
BLOCK_SCAN_RADIUS=32
ENTITY_SCAN_RADIUS=32

# Action Agent
ACTION_MAX_RETRIES=3
ACTION_RETRY_DELAY_MS=2000
ACTION_TIMEOUT_MS=90000

# Skill Library
SKILLS_LIBRARY_DIR=src/skills/learned

# Logging (debug | info | warn | error)
LOG_LEVEL=info
